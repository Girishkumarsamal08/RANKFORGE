# ==========================================
# RANKFORGE ENVIRONMENT CONFIGURATION
# ==========================================

# Core Application Environment
NODE_ENV=development
PORT=5000

# Security
JWT_SECRET=your_jwt_super_secret_key_change_me
JWT_EXPIRES_IN=7d

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://rankforge_user:securepassword@postgres:5432/rankforge_db?schema=public

# Redis Configuration
REDIS_URL=redis://redis:6379

# AI Engine Service Configuration
AI_ENGINE_URL=http://ai-engine:8000


# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:5001/api
